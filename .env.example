# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=

# Admin auth — required; set to a random 32+ byte hex string, not the admin password.
ADMIN_SESSION_SECRET=
ADMIN_PASSWORD=

# Captain session signing key — falls back to ADMIN_SESSION_SECRET if not set.
# Set a separate long random string here to isolate captain session signing.
CAPTAIN_SESSION_SECRET=

# Discord OAuth (admin login)
DISCORD_ADMIN_CLIENT_ID=
DISCORD_ADMIN_CLIENT_SECRET=
DISCORD_ADMIN_REDIRECT_URI=

# Site URL (used for OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Discord webhook URL for server-side error alerts (#80).
# When set, failures in draft picks, standings recalculation, and match-report
# submission are posted to this channel in addition to function logs.
DISCORD_ERROR_WEBHOOK_URL=
