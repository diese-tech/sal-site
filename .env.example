# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin auth — set a long random string for ADMIN_SESSION_SECRET
ADMIN_SESSION_SECRET=
# ADMIN_PASSWORD is used as a fallback signing key when ADMIN_SESSION_SECRET is not set.
# In production, always set ADMIN_SESSION_SECRET instead.
ADMIN_PASSWORD=

# Discord OAuth (admin login)
DISCORD_ADMIN_CLIENT_ID=
DISCORD_ADMIN_CLIENT_SECRET=
DISCORD_ADMIN_REDIRECT_URI=

# Site URL (used for OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
