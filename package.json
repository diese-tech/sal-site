{
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "audit:full": "npm audit --audit-level=high",
    "audit:production": "npm audit --omit=dev --audit-level=high",
    "dev": "next dev",
    "build": "next build",
    "check:bem": "node scripts/check-bem.mjs",
    "start": "next start",
    "lint": "eslint",
