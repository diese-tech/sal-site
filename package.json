    "test:e2e": "playwright test",
    "test:integration": "vitest run tests/integration",
    "db:seed": "tsx scripts/seed-supabase.mjs",
    "check:db-contract": "node scripts/db-contract.mjs check src/types/database.types.ts",
    "sync:db-contract": "node scripts/db-contract.mjs sync src/types/database.types.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.105.4",
    "clsx": "^2.1.1",
